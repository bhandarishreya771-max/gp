features = (
{
code = "# Half Forms\nsub ka-deva virama-deva by ka-deva.half;\nsub va-deva virama-deva by va-deva.half;\nsub ba-deva virama-deva by ba-deva.half;\nsub la-deva virama-deva by la-deva.half;\nsub na-deva virama-deva by na-deva.half;\nsub pha-deva virama-deva by pha-deva.half;\nsub sa-deva virama-deva by sa-deva.half;\nsub ga-deva virama-deva by ga-deva.half;\nsub kha-deva virama-deva by kha-deva.half;\nsub sha-deva virama-deva by sha-deva.half;\nsub ssa-deva virama-deva by ssa-deva.half;\nsub bha-deva virama-deva by bha-deva.half;";
tag = half;
},
{
code = "    lookup PA_BEFORE_U_SIGN {\n        lookupflag 0;\n        sub pa-deva' usign-deva by pa-deva.matra;\n        sub pa-deva' uusign-deva by pa-deva.matra;\n    } PA_BEFORE_U_SIGN;\n#> feature\n#< feature";
tag = blws;
},
{
code = "    sub ka-deva iisign-deva' by iisign-deva.002;\n    sub pha-deva iisign-deva' by iisign-deva.002;\n\n    sub ka-deva isign-deva' by isign-deva.002;\n    sub pha-deva isign-deva' by isign-deva.002;\n    sub da-deva isign-deva' by isign-deva.002;\n    sub tta-deva isign-deva' by isign-deva.002;\n    sub ttha-deva isign-deva' by isign-deva.002;\n    sub dda-deva isign-deva' by isign-deva.002;\n    sub ddha-deva isign-deva' by isign-deva.002;\n    sub pa-deva isign-deva' by isign-deva.002;\n\n  sub ta-deva isign-deva' by isign-deva.003;\n    sub na-deva isign-deva' by isign-deva.003;\n    sub ga-deva isign-deva' by isign-deva.003;\n    sub ba-deva isign-deva' by isign-deva.003;\n    sub va-deva isign-deva' by isign-deva.003;\n    sub bha-deva isign-deva' by isign-deva.003;\n    sub ma-deva isign-deva' by isign-deva.003;\n    sub ya-deva isign-deva' by isign-deva.003;\n\n\n    sub gha-deva isign-deva' by isign-deva.004;\n    sub dha-deva isign-deva' by isign-deva.004;\n    sub ca-deva isign-deva' by isign-deva.004;\n    sub jha-deva isign-deva' by isign-deva.004;\n    sub nya-deva isign-deva' by isign-deva.004;\n    sub la-deva isign-deva' by isign-deva.004;\n    sub sa-deva isign-deva' by isign-deva.004;\n    sub tha-deva isign-deva' by isign-deva.004;";
tag = calt;
},
{
code = "#> feature\n# GPOS feature : Mark Positioning\n    markClass usign-deva <anchor -100 0> @bottom;\n    markClass uusign-deva <anchor -100 0> @bottom;\n    markClass esign-deva <anchor -140 700> @top;\n    markClass aisign-deva <anchor 340 700> @top;\n    markClass virama-deva <anchor 271 -40> @bottom;\n\n  lookup markLTR {\n      pos base ka-deva\n          <anchor 460 0> mark @bottom\n          <anchor 141 -1523> mark @top;\n      pos base kha-deva\n          <anchor 680 0> mark @bottom\n          <anchor 622 700> mark @top;\n      pos base ga-deva\n          <anchor 520 0> mark @bottom\n          <anchor 478 700> mark @top;\n      pos base gha-deva\n          <anchor 580 0> mark @bottom\n          <anchor 543 700> mark @top;\n      pos base nga-deva\n          <anchor 395 700> mark @top;\n      pos base ca-deva\n          <anchor 560 0> mark @bottom\n          <anchor 521 700> mark @top;\n      pos base cha-deva\n          <anchor 500 0> mark @bottom\n          <anchor 529 700> mark @top;\n      pos base ja-deva\n          <anchor 578 0> mark @bottom\n          <anchor 542 700> mark @top;\n      pos base jha-deva\n          <anchor 678 0> mark @bottom\n          <anchor 658 700> mark @top;\n      pos base nya-deva\n          <anchor 585 0> mark @bottom\n          <anchor 559 700> mark @top;\n      pos base tta-deva\n          <anchor 445 0> mark @bottom\n          <anchor 415 700> mark @top;\n      pos base ttha-deva\n          <anchor 481 0> mark @bottom\n          <anchor 433 700> mark @top;\n      pos base dda-deva\n          <anchor 380 0> mark @bottom\n          <anchor 397 700> mark @top;\n      pos base ddha-deva\n          <anchor 466 0> mark @bottom\n          <anchor 420 700> mark @top;\n      pos base ta-deva\n          <anchor 519 0> mark @bottom\n          <anchor 482 700> mark @top;\n      pos base tha-deva\n          <anchor 586 0> mark @bottom\n          <anchor 527 700> mark @top;\n      pos base da-deva\n          <anchor 398 0> mark @bottom\n          <anchor 400 700> mark @top;\n      pos base dha-deva\n          <anchor 600 0> mark @bottom\n          <anchor 543 700> mark @top;\n      pos base na-deva\n          <anchor 519 0> mark @bottom\n          <anchor 478 700> mark @top;\n      pos base pa-deva\n          <anchor 480 0> mark @bottom\n          <anchor 440 700> mark @top;\n      pos base pha-deva\n          <anchor 504 0> mark @bottom\n          <anchor 440 700> mark @top;\n      pos base ba-deva\n          <anchor 478 0> mark @bottom\n          <anchor 424 700> mark @top;\n      pos base bha-deva\n          <anchor 541 0> mark @bottom\n          <anchor 483 700> mark @top;\n      pos base ma-deva\n          <anchor 522 0> mark @bottom\n          <anchor 485 700> mark @top;\n      pos base ya-deva\n          <anchor 541 0> mark @bottom\n          <anchor 480 700> mark @top;\n      pos base ra-deva\n          <anchor 410 440> mark @bottom\n          <anchor 169 700> mark @top;\n      pos base la-deva\n          <anchor 619 -20> mark @bottom\n          <anchor 553 700> mark @top;\n      pos base va-deva\n          <anchor 460 0> mark @bottom\n          <anchor 415 700> mark @top;\n      pos base sha-deva\n          <anchor 654 0> mark @bottom\n          <anchor 594 700> mark @top;\n      pos base ssa-deva\n          <anchor 499 0> mark @bottom\n          <anchor 438 700> mark @top;\n      pos base sa-deva\n          <anchor 620 0> mark @bottom\n          <anchor 554 700> mark @top;\n      pos base ha-deva\n          <anchor 332 -40> mark @bottom\n          <anchor 360 700> mark @top;\n      pos base gya-deva\n          <anchor 601 0> mark @bottom\n          <anchor 547 700> mark @top;\n      pos base ka-deva.half\n          <anchor 460 0> mark @bottom\n          <anchor 141 -1523> mark @top;\n      pos base ba-deva.half\n          <anchor 478 0> mark @bottom\n          <anchor 447 700> mark @top;\n      pos base va-deva.half\n          <anchor 460 0> mark @bottom\n          <anchor 433 700> mark @top;\n      pos base ta-deva.half\n          <anchor 519 0> mark @bottom\n          <anchor 482 700> mark @top;\n      pos base la-deva.half\n          <anchor 619 0> mark @bottom\n          <anchor 576 700> mark @top;\n      pos base na-deva.half\n          <anchor 519 0> mark @bottom\n          <anchor 478 700> mark @top;\n      pos base ma-deva.half\n          <anchor 522 0> mark @bottom\n          <anchor 485 700> mark @top;\n      pos base pha-deva.half\n          <anchor 504 0> mark @bottom\n          <anchor 462 700> mark @top;\n      pos base sa-deva.half\n          <anchor 620 0> mark @bottom\n          <anchor 575 700> mark @top;\n      pos base ga-deva.half\n          <anchor 520 0> mark @bottom\n          <anchor 478 700> mark @top;\n      pos base kha-deva.half\n          <anchor 680 0> mark @bottom\n          <anchor 649 700> mark @top;\n      pos base ssa-deva.half\n          <anchor 499 0> mark @bottom\n          <anchor 469 700> mark @top;\n      pos base bha-deva.half\n          <anchor 541 0> mark @bottom\n          <anchor 505 700> mark @top;\n      pos base tta-deva.half\n          <anchor 445 0> mark @bottom\n          <anchor 415 700> mark @top;\n      pos base ttha-deva.half\n          <anchor 481 0> mark @bottom\n          <anchor 433 700> mark @top;\n  } markLTR;\n\n  lookup markLTR;\n#< feature";
